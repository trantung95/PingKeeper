{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "PingKeeper": "Debug"
    }
  },
  "PingKeeper": {
    "IntervalSeconds": 60,
    "TimeoutSeconds": 10,
    "ConsecutiveFailureThreshold": 3,
    "Endpoints": [
      {
        "Name": "Self",
        "Url": "https://my-instance.example.com/ping"
      }
    ]
  },
  "Webhook": {
    "Url": "",
    "TimeoutSeconds": 15,
    "NotifyOnRecovery": true
  }
}
